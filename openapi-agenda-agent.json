{
  "openapi": "3.1.0",
  "info": {
    "title": "Agenda Lagares — Agent API",
    "description": "Operacoes compactas de tarefas na Agenda Lagares. Sempre chame 'brief' antes de escrever, para obter a 'version' atual, e envie essa mesma version em expected_version. Nao expoe SQL nem outras tabelas.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://uabpevnjfcwidbjscowq.supabase.co/functions/v1" }
  ],
  "paths": {
    "/agenda-agent": {
      "post": {
        "operationId": "agendaAgent",
        "summary": "Ler (brief) ou editar tarefas (create, complete, patch)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": ["brief", "create", "complete", "patch"],
                    "description": "brief = ler estado e version; create = nova tarefa; complete = concluir; patch = editar/reagendar."
                  },
                  "expected_version": {
                    "type": "integer",
                    "description": "Obrigatorio em create/complete/patch. Use a 'version' devolvida pelo brief mais recente."
                  },
                  "id": {
                    "type": "string",
                    "description": "id da tarefa (complete/patch)."
                  },
                  "task": {
                    "type": "object",
                    "description": "Dados da nova tarefa (create).",
                    "properties": {
                      "text": { "type": "string" },
                      "date": { "type": "string", "description": "YYYY-MM-DD" },
                      "time": { "type": "string", "description": "HH:MM ou vazio" },
                      "tag": { "type": "string", "enum": ["trabalho", "pessoal", "casa", "faculdade", "saude", "financeiro", "outros"] },
                      "reminder": { "type": "integer", "description": "minutos antes; -1 = sem lembrete" }
                    }
                  },
                  "patch": {
                    "type": "object",
                    "description": "Campos a alterar (patch): text, date, time, tag, reminder, done, flag.",
                    "properties": {
                      "text": { "type": "string" },
                      "date": { "type": "string" },
                      "time": { "type": "string" },
                      "tag": { "type": "string" },
                      "reminder": { "type": "integer" },
                      "done": { "type": "boolean" },
                      "flag": { "type": "string" }
                    }
                  },
                  "note": {
                    "type": "object",
                    "description": "Opcional. Extras da tarefa e, para lancamentos do Painel Financeiro, os campos abaixo. Financeiro = tag 'financeiro' + note com movimento/valor/forma.",
                    "properties": {
                      "movimento": { "type": "string", "enum": ["entrada", "saida"], "description": "Direcao do dinheiro (obrigatorio para o financeiro)." },
                      "valor": { "type": "string", "description": "Valor em reais como texto, ex. '141.80'." },
                      "forma": { "type": "string", "enum": ["inter", "pix", "dinheiro", "mp"], "description": "Forma de pagamento da saida. inter=cartao Inter, pix/dinheiro=descontam do saldo, mp=Mercado Pago." },
                      "conta": { "type": "string", "enum": ["mp", "nb"], "description": "Conta de origem quando forma=pix (mp=Mercado Pago, nb=Nubank)." },
                      "programada": { "type": "boolean", "description": "true = saida futura ainda nao paga (mantem checkbox e nao desconta o saldo ate ser marcada)." },
                      "vence": { "type": "string", "description": "Data de vencimento de uma cobranca (entrada), YYYY-MM-DD." },
                      "valorJuros": { "type": "string", "description": "Valor com juros se a cobranca atrasar." },
                      "detail": { "type": "string" },
                      "durationMin": { "type": "integer" },
                      "parcPagas": { "type": "string", "description": "Numero da parcela paga (ex. '2')." },
                      "parcRest": { "type": "string", "description": "Parcelas restantes (ex. '5')." }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Chave invalida" },
          "409": { "description": "Conflito de versao — refaca o brief e tente de novo" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AgentKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-agenda-agent-key"
      }
    }
  },
  "security": [ { "AgentKey": [] } ]
}
